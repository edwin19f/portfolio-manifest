{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Edwin portfolio manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "owner", "githubUser", "headline", "subheadline", "projects"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "githubUser": { "type": "string", "minLength": 1 },
    "headline": { "type": "string", "minLength": 1 },
    "subheadline": { "type": "string", "minLength": 1 },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/project" }
    }
  },
  "definitions": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug", "order", "title", "tagline", "brainRegion", "problem",
        "architecture", "stack", "skills", "role", "status", "accent"
      ],
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "order": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "tagline": { "type": "string", "minLength": 1 },
        "brainRegion": { "type": "string", "minLength": 1 },
        "problem": { "type": "string", "minLength": 1 },
        "architecture": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "stack": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "skills": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "role": { "type": "string", "minLength": 1 },
        "proof": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "status": { "type": "string", "enum": ["live", "public", "case-study", "archived"] },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "live": { "type": "string", "format": "uri" },
            "repo": { "type": "string", "format": "uri" },
            "case_study": { "type": "string" }
          }
        },
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    }
  }
}
